# ── Live IOC feed API keys ─────────────────────────────────────────────────────
# AlienVault OTX (free): https://otx.alienvault.com/settings
RISKINTEL_OTX_API_KEY=

# AbuseIPDB (free tier: 1000 checks/day): https://www.abuseipdb.com/api
RISKINTEL_ABUSEIPDB_API_KEY=

# VirusTotal (free: 4 req/min): https://www.virustotal.com/gui/my-apikey
RISKINTEL_VT_API_KEY=

# ── Performance tuning ────────────────────────────────────────────────────────
# Max worker threads for the engine thread pool (default: 20)
# RISKINTEL_THREAD_WORKERS=20

# Response cache TTL in seconds (default: 60)
# RISKINTEL_CACHE_TTL=60
